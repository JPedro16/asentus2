{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Open in Browser",
            "type": "shell",
            "command": "start",
            "args": ["${workspaceFolder}/index.html"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "windows": {
                "command": "cmd",
                "args": ["/c", "start", "${workspaceFolder}/index.html"]
            }
        }
    ]
}